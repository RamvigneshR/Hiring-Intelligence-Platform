# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password

# API configuration
WEBSITE_URL=https://example.com/api

# Data fetching configuration
PAGES_TO_RUN=2
STORAGE_PATH=/path/to/your/folder

# Run date
# Leave empty for current date run
# Use format YYYY_MM_DD for backprocessing
RUN_DATE=